{
  "name": "prompt-queue-usage-monitor",
  "displayName": "Prompt Queue + Usage Monitor",
  "description": "Queue prompts for later delivery (rate-limit bypass) and monitor AI token usage (Claude / OpenAI Codex).",
  "version": "0.3.4",
  "publisher": "v0latix",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/V0latix/vscode_claudecode_sendlater.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "openai",
    "codex",
    "prompt",
    "queue",
    "rate-limit",
    "usage",
    "tokens"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "promptQueue.queuePrompt",
        "title": "Queue Prompt (Send Later)",
        "category": "PromptQueue"
      },
      {
        "command": "promptQueue.queueFromClipboard",
        "title": "Queue From Clipboard",
        "category": "PromptQueue"
      },
      {
        "command": "promptQueue.queueFromEditor",
        "title": "Queue From Current Editor",
        "category": "PromptQueue"
      },
      {
        "command": "promptQueue.imRateLimited",
        "title": "I'm Rate Limited — Queue for Later",
        "category": "PromptQueue"
      },
      {
        "command": "promptQueue.processNow",
        "title": "Process Queue Now",
        "category": "PromptQueue"
      },
      {
        "command": "usage.refresh",
        "title": "Refresh Usage",
        "category": "Usage",
        "icon": "$(refresh)"
      },
      {
        "command": "usage.showSummary",
        "title": "Show Usage Summary",
        "category": "Usage"
      },
      {
        "command": "usage.setOpenAIKey",
        "title": "Set OpenAI API Key (Secret)",
        "category": "Usage"
      },
      {
        "command": "usage.setAnthropicKey",
        "title": "Set Anthropic Admin API Key (Secret)",
        "category": "Usage"
      },
      {
        "command": "usage.clearOpenAIKey",
        "title": "Clear OpenAI API Key",
        "category": "Usage"
      },
      {
        "command": "usage.clearAnthropicKey",
        "title": "Clear Anthropic Admin API Key",
        "category": "Usage"
      },
      {
        "command": "usage.setLimits",
        "title": "Calibrate Limits from claude.ai %",
        "category": "Usage"
      }
    ],
    "configuration": {
      "title": "Prompt Queue + Usage Monitor",
      "properties": {
        "promptQueue.defaultDelayMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "description": "Default delay (minutes) when queueing a prompt."
        },
        "promptQueue.outputDir": {
          "type": "string",
          "default": ".prompt-queue",
          "description": "Workspace-relative directory where delivered prompt files are created."
        },
        "promptQueue.filenameTemplate": {
          "type": "string",
          "default": "{timestamp}_{id}.md",
          "description": "Filename template. {timestamp} → YYYYMMDD_HHMM, {id} → short id."
        },
        "promptQueue.targetTerminalName": {
          "type": "string",
          "default": "",
          "description": "Exact name of the terminal to target when delivering prompts. Leave empty for auto-detection (looks for a Claude terminal)."
        },
        "openai.orgId": {
          "type": "string",
          "default": "",
          "pattern": "^(org-[a-zA-Z0-9_-]+)?$",
          "patternErrorMessage": "Must start with 'org-' (e.g. org-abc123) or be empty.",
          "description": "OpenAI Organization ID (optional, sent as Openai-Organization header)."
        },
        "openai.projectId": {
          "type": "string",
          "default": "",
          "pattern": "^(proj-[a-zA-Z0-9_-]+)?$",
          "patternErrorMessage": "Must start with 'proj-' (e.g. proj-abc123) or be empty.",
          "description": "OpenAI Project ID (optional, sent as Openai-Project header)."
        },
        "anthropic.orgId": {
          "type": "string",
          "default": "",
          "description": "Anthropic Organization/Workspace ID (optional, used in API path)."
        },
        "promptQueue.maxDeliveryRetries": {
          "type": "number",
          "default": 3,
          "minimum": 0,
          "maximum": 10,
          "description": "Maximum delivery retry attempts when a terminal is not found. Each retry uses exponential backoff (60s, 120s, 240s…). Set 0 to disable retries."
        },
        "usage.refreshIntervalMinutes": {
          "type": "number",
          "default": 10,
          "minimum": 0,
          "description": "Auto-refresh interval for usage data (minutes). Set 0 to disable."
        },
        "usage.quotaAlertThreshold": {
          "type": "number",
          "default": 80,
          "minimum": 0,
          "maximum": 100,
          "description": "Show a warning notification when 5h usage exceeds this % of the configured limit. Set 0 to disable."
        },
        "claude.tokenLimit5h": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Claude token limit for the 5-hour rolling window. Set via 'Usage: Calibrate Limits' command."
        },
        "claude.tokenLimitWeekly": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Claude token limit for the weekly window. Set via 'Usage: Calibrate Limits' command."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "promptQueueContainer",
          "title": "Prompt Queue",
          "icon": "media/activitybar-icon.svg"
        }
      ]
    },
    "views": {
      "promptQueueContainer": [
        {
          "id": "usageMonitorView",
          "name": "Usage Monitor",
          "type": "webview"
        },
        {
          "id": "promptQueueView",
          "name": "Prompt Queue",
          "type": "webview"
        },
        {
          "id": "claudeCommandsView",
          "name": "Claude Commands",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "usage.refresh",
          "when": "view == usageMonitorView",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "usage.refresh"
        },
        {
          "command": "usage.showSummary"
        },
        {
          "command": "usage.setOpenAIKey"
        },
        {
          "command": "usage.setAnthropicKey"
        },
        {
          "command": "usage.clearOpenAIKey"
        },
        {
          "command": "usage.clearAnthropicKey"
        },
        {
          "command": "usage.setLimits"
        },
        {
          "command": "promptQueue.queuePrompt"
        },
        {
          "command": "promptQueue.queueFromClipboard"
        },
        {
          "command": "promptQueue.queueFromEditor"
        },
        {
          "command": "promptQueue.imRateLimited"
        },
        {
          "command": "promptQueue.processNow"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.23.0",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3"
  }
}
